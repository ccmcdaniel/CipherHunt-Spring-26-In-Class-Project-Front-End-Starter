#:kivy 1.0
#:import utils kivy.utils

<VaultScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 60

        BoxLayout:
            orientation: 'vertical'
            spacing: 5

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex("#384f77")
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [8]


            Label:
                text: "[b][size=50]Created By[/size][/b]\n{name}{date}"
                markup: True
                size_hint: (1, None)
                height: '70dp'
                color: utils.get_color_from_hex("#FFFFFF")
                halign: 'center'

            BoxLayout:
                size_hint: (1, None)
                height: "8dp"

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#b7b7b7")
                    Rectangle:
                        size: self.size
                        pos: self.pos


            # Line ???

            BoxLayout:
                orientation: 'vertical'
                spacing: 25
                padding: 10

                Label:
                    text: "riddle/clue"
                    font_size: '32sp'
                    color: utils.get_color_from_hex("#FFFFFF")

                TextInput:
                    hint_text: "key"
                    size_hint: (1, None)
                    height: '60dp'
                

                AppButton:
                    text: "[b]Submit[/b]"

                AppButton:
                    text: "[b]Fetch Clue[/b]"


<AppButton@Button>:
    markup: True
    size_hint: (1, None)
    height: '60dp'
    background_normal: ''
    background_color: (0, 0, 0, 0)
    font_size: '24sp'

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#68b3b7")
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [8]
            