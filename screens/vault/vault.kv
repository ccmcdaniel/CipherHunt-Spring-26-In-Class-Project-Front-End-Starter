#:kivy 1.0
#:import utils kivy.utils

<VaultScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 60

        BoxLayout:
            orientation: 'vertical'

            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex("#1f3d6c")
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [20]
            
            Label:
                text: "[b][size=50]Created By[/size][/b]\n{name}, {date}"
                markup: True
                color: utils.get_color_from_hex("#ffffff")
                halign: 'center'
                size_hint: (1, None)
                height: '80dp'

            Widget:
                size_hint: (1, None)
                height: "8dp"

                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#9e9e9e")
                    Rectangle:
                        size: self.size
                        pos: self.pos

            BoxLayout:
                orientation: 'vertical'
                padding: 40
                spacing: 25

                Label:
                    text: "Riddle"
                    font_size: '25sp'
                    color: utils.get_color_from_hex("#ffffff")

                TextInput:
                    hint_text: "Key"
                    size_hint: (1, None)
                    height: '60dp'

                AppButton:
                    text: "Submit"
                
                AppButton:
                    text: "Fetch New Task"


<AppButton@Button>:
    size_hint: (1, None)
    height: '40dp'
    font_size: '20sp'
    bold: True

    background_normal: ''
    background_color: (0, 0, 0, 0)

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#2adae3")
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [15]